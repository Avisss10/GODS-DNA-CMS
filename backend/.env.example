NODE_ENV=development
PORT=3000

# CORS — daftar origin yang diizinkan, dipisah koma (tanpa spasi wajib).
# Request tanpa Origin (server-to-server/curl/Postman) selalu diizinkan.
# Contoh: ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
ALLOWED_ORIGINS=http://localhost:5173

# Database (TiDB Cloud - MySQL compatible, wajib TLS)
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=gods_dna_cms
DB_POOL_SIZE=10

# Path ke CA certificate untuk koneksi TLS ke TiDB Cloud.
# Download dari dashboard TiDB Cloud: Connect > Public > CA cert
# Kosongkan jika koneksi ke MySQL lokal tanpa TLS (dev only).
DB_SSL_CA_PATH=src/config/certs/ca.pem

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# AES-256-CBC encryption key (32 bytes, hex string)
AES_ENCRYPTION_KEY=

# Audit Log HMAC secret
AUDIT_HMAC_SECRET=

# Recovery Code (BAGIAN 1.3) — offline, developer-only.
# Generate dengan: node src/scripts/generate-recovery-code.js
# Simpan RECOVERY_CODE_HASH di .env, dan recovery code asli (plaintext)
# disimpan secara OFFLINE oleh developer (misal dicetak/disimpan terpisah).
RECOVERY_CODE_HASH=

# Redis (Bull queue, session/login attempt cache)
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false