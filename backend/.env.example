NODE_ENV=development
PORT=3000

# Database (TiDB Cloud - MySQL compatible, wajib TLS)
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=gods_dna_cms
DB_POOL_SIZE=10

# Path ke CA certificate untuk koneksi TLS ke TiDB Cloud.
# Download dari dashboard TiDB Cloud: Connect > Public > CA cert
# Kosongkan jika koneksi ke MySQL lokal tanpa TLS (dev only).
DB_SSL_CA_PATH=src/config/certs/ca.pem

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# AES-256-CBC encryption key (32 bytes, hex string)
AES_ENCRYPTION_KEY=

# Audit Log HMAC secret
AUDIT_HMAC_SECRET=

# Redis (Bull queue, session/login attempt cache)
REDIS_HOST=
REDIS_PORT=6379